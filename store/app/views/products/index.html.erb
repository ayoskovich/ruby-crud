<!-- "." is a relative lookup based on the controller
  and action. This does "en.products.index.title"
-->
<h1><%= t ".title" %></h1>

<%= link_to "Add a product", new_product_path if authenticated? %>
<div id="products">
  <% @products.each do |product| %>
    <div>
      <%= link_to product.name, product_path(product.id), class: "text-link" %>
    </div>
  <% end %>
</div>
